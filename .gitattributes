# === Line endings ===
* text=auto eol=lf

# === PHP ===
*.php text eol=lf diff=php

# === Web assets ===
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.svg text eol=lf

# === Docs / Config ===
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.pot text eol=lf
*.po text eol=lf

# === Binary (no diff, no merge, no line-ending conversion) ===
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mo binary
*.zip binary

# === Export-ignore (excluded from git archive / GitHub release zips) ===
.gitignore export-ignore
.gitattributes export-ignore
.github/ export-ignore
tests/ export-ignore
phpcs.xml export-ignore
phpunit.xml export-ignore
.editorconfig export-ignore
*.dist export-ignore
index.html export-ignore
README.md export-ignore